ENVIRONMENT=development
APP_HOST=app.example.com
DISTRIBUTION_ROOT=sites.example.com
CLOUDFLARE_WORKER_SCRIPT=qingnest-worker
PUBLIC_PROTOCOL=https
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=noreply@mail.985201314.xyz
RESEND_FROM_NAME=QingNest 轻巢
FM_API_BASE_URL=https://replace-with-fm-api-host
FM_MERCHANT_NUM=replace-with-fm-merchant-number
FM_SECRET=replace-with-fm-secret
FM_PAY_TYPE=aloop
FM_NOTIFY_URL=https://api.example.com/api/payments/fm/notify
FM_RETURN_URL=https://app.example.com/studio/billing/payment-result
# 可选安全加固；不配置时接受 FM 通过 HTTPS 返回的支付链接。
FM_PAY_URL_HOSTS=
FM_QUERY_ENABLED=false
