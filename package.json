{
  "name": "qingnest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build": "tsc -b && vite build --config apps/web/vite.config.ts",
    "preview": "vite preview --config apps/web/vite.config.ts --host 0.0.0.0",
    "worker:dev": "wrangler dev --config apps/worker/wrangler.toml",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:db:reset": "supabase db reset",
    "supabase:db:push": "supabase db push",
    "supabase:db:lint": "supabase db lint --local --schema public --fail-on warning",
    "supabase:advisors": "supabase db advisors --local",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@supabase/supabase-js": "2.110.0",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "framer-motion": "^12.42.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260702.1",
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "supabase": "2.109.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "wrangler": "^4.107.0"
  },
  "engines": {
    "node": ">=20"
  }
}
