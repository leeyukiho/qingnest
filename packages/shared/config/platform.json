  "deployment": {
    "acceptedArchiveExtensions": [".zip"],
    "entrypoints": ["index.html"],
    "staticOutputDirectories": ["dist", "build", "out", "public"],
    "sourceIndicators": ["package.json", "vite.config.ts", "vite.config.js", "next.config.js", "nuxt.config.ts"],
    "blockedPaths": [
      ".git/",
      ".github/",
      ".env",
      ".env.local",
      ".env.production",
      "node_modules/",
      "coverage/",
      ".next/cache/",
      "private.key",
      "id_rsa",
      "id_ed25519"
